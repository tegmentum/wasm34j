<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter
    xmlns="https://github.com/spotbugs/filter/3.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0 
                        https://raw.githubusercontent.com/spotbugs/spotbugs/3.1.0/spotbugs/etc/findbugsfilter.xsd">
    
    <!-- Exclude auto-generated code -->
    <Match>
        <Package name="~.*\.generated\..*"/>
    </Match>
    
    <!-- Exclude test utility classes -->
    <Match>
        <Class name="~.*Test.*"/>
        <Bug pattern="DM_EXIT"/>
    </Match>
    
    <!-- Exclude benchmark classes from performance warnings -->
    <Match>
        <Package name="~.*\.benchmark.*"/>
        <Bug pattern="DM_GC"/>
    </Match>
    
    <!-- Native code JNI exclusions -->
    <Match>
        <Package name="~.*\.jni\..*"/>
        <Bug pattern="UPM_UNCALLED_PRIVATE_METHOD"/>
    </Match>
    
    <!-- Panama FFI exclusions -->
    <Match>
        <Package name="~.*\.panama\..*"/>
        <Bug pattern="UPM_UNCALLED_PRIVATE_METHOD"/>
    </Match>

    <!-- findsecbugs flags String.toLowerCase even with Locale.ROOT (the correct secure form). -->
    <Match>
        <Bug pattern="IMPROPER_UNICODE"/>
    </Match>

    <!-- False positive: WasmImports is a builder/value type, not a singleton; the detector is
         confused by the static EMPTY instance plus the synthetic constructor parameter. -->
    <Match>
        <Class name="ai.tegmentum.wasm34j.WasmImports"/>
        <Bug pattern="SING_SINGLETON_HAS_NONPRIVATE_CONSTRUCTOR"/>
    </Match>
</FindBugsFilter>